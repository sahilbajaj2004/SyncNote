{
  "name": "syncnote",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "client": "npm --prefix client run dev",
    "server": "npm --prefix server run dev",
    "dev": "concurrently -n server,client -c yellow,cyan \"npm run server\" \"npm run client\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}